# S3 settings for image uploads
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-northeast-1
S3_BUCKET=your-bucket-name
# Optional
S3_PREFIX=shops
# Example for CloudFront or custom domain
# S3_PUBLIC_BASE_URL=https://cdn.example.com
# Optional for S3-compatible storage
# S3_ENDPOINT_URL=https://<endpoint>
# Optional. Leave blank if bucket policy handles public access
# S3_ACL=public-read
